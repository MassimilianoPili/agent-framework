{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AgentManifest.schema.json",
  "title": "AgentManifest",
  "description": "Schema for agent manifest YAML files used by agent-compiler-maven-plugin to generate worker implementations at compile time.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "agent-framework/v1",
      "description": "API version of the manifest format."
    },
    "kind": {
      "type": "string",
      "const": "AgentManifest",
      "description": "Resource kind identifier."
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique kebab-case name for this worker (e.g., 'be-java-worker')."
        },
        "displayName": {
          "type": "string",
          "description": "Human-readable display name."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of what this worker does."
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["workerType", "topic", "subscription", "prompts", "tools"],
      "additionalProperties": false,
      "properties": {
        "workerType": {
          "type": "string",
          "enum": ["BE", "FE", "AI_TASK", "CONTRACT", "REVIEW"],
          "description": "Worker type identifier. Must match WorkerType enum in orchestrator."
        },
        "workerProfile": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Profile identifier for multi-stack routing (e.g., 'be-java'). Null for non-profileable workers."
        },
        "topic": {
          "type": "string",
          "description": "Azure Service Bus topic name for task consumption."
        },
        "subscription": {
          "type": "string",
          "description": "Azure Service Bus subscription name."
        },
        "model": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "default": "claude-sonnet-4-6",
              "description": "AI model identifier."
            },
            "maxTokens": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200000,
              "default": 16384,
              "description": "Maximum output tokens per request."
            },
            "temperature": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "default": 0.2,
              "description": "Sampling temperature."
            }
          }
        },
        "prompts": {
          "type": "object",
          "required": ["systemPromptFile", "instructions"],
          "additionalProperties": false,
          "properties": {
            "systemPromptFile": {
              "type": "string",
              "description": "Classpath or filesystem path to the primary system prompt Markdown file."
            },
            "skills": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Additional skill file paths to compose into the system prompt."
            },
            "instructions": {
              "type": "string",
              "description": "Worker-specific instruction text appended to the user prompt."
            },
            "resultSchema": {
              "type": "string",
              "description": "JSON schema string describing the expected result format."
            }
          }
        },
        "tools": {
          "type": "object",
          "required": ["allowlist"],
          "additionalProperties": false,
          "properties": {
            "dependencies": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Maven coordinates (groupId:artifactId) of MCP tool starters to include in the generated pom.xml."
            },
            "allowlist": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "List of MCP tool names this worker is allowed to use at runtime."
            }
          }
        },
        "ownership": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ownsPaths": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Paths this worker can read and write."
            },
            "readOnlyPaths": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Paths this worker can only read."
            }
          }
        },
        "concurrency": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxConcurrentCalls": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 3,
              "description": "Maximum number of concurrent tool calls."
            }
          }
        }
      }
    }
  }
}
