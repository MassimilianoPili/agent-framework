# Sandbox image for Go 1.22 compilation
# Security: runs as non-root (UID 1000), no network, read-only root filesystem
FROM golang:1.22-alpine

RUN apk add --no-cache git && \
    adduser -D -u 1000 sandbox && \
    mkdir -p /code /out && \
    chown 1000:1000 /code /out

# Pre-create GOPATH directories writable by sandbox user
ENV GOPATH=/tmp/go
RUN mkdir -p /tmp/go && chown -R 1000:1000 /tmp/go

USER 1000:1000
WORKDIR /code
