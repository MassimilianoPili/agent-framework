{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mcp-openapi-tool-io.schema.json",
  "title": "OpenAPI MCP Server Tool I/O",
  "description": "Input/output contracts for the openapi MCP server tools",
  "definitions": {
    "SpectralLintInput": {
      "type": "object",
      "required": ["specPath"],
      "properties": {
        "specPath": { "type": "string", "description": "Path to OpenAPI spec file" },
        "rulesetPath": { "type": "string", "description": "Path to Spectral ruleset; defaults to project rules" }
      },
      "additionalProperties": false
    },
    "SpectralLintOutput": {
      "type": "object",
      "properties": {
        "errors": { "type": "integer" },
        "warnings": { "type": "integer" },
        "infos": { "type": "integer" },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "severity": { "type": "string", "enum": ["error", "warn", "info", "hint"] },
              "path": { "type": "array", "items": { "type": "string" } },
              "line": { "type": "integer" }
            }
          }
        }
      }
    },
    "OasdiffBreakingInput": {
      "type": "object",
      "required": ["basePath", "revisionPath"],
      "properties": {
        "basePath": { "type": "string", "description": "Path to base (old) OpenAPI spec" },
        "revisionPath": { "type": "string", "description": "Path to revision (new) OpenAPI spec" }
      },
      "additionalProperties": false
    },
    "OasdiffBreakingOutput": {
      "type": "object",
      "properties": {
        "breakingChanges": { "type": "integer" },
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "level": { "type": "string", "enum": ["error", "warning"] },
              "operation": { "type": "string" },
              "path": { "type": "string" }
            }
          }
        }
      }
    },
    "GenerateClientInput": {
      "type": "object",
      "required": ["specPath", "language"],
      "properties": {
        "specPath": { "type": "string" },
        "language": { "type": "string", "enum": ["typescript", "java"] },
        "outputDir": { "type": "string" }
      },
      "additionalProperties": false
    },
    "GenerateClientOutput": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean" },
        "filesGenerated": { "type": "array", "items": { "type": "string" } },
        "outputDir": { "type": "string" }
      }
    }
  }
}
